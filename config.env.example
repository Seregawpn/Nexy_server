# =====================================================
# SERVER CONFIG EXAMPLE
# =====================================================
# Без реальных секретов. Только плейсхолдеры.

# =====================================================
# ENVIRONMENT
# =====================================================
NEXY_ENV=dev

# =====================================================
# GEMINI / TEXT PROCESSING
# =====================================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_FALLBACK_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_USE_VERTEX_AI=true
GOOGLE_CLOUD_PROJECT=YOUR_GOOGLE_CLOUD_PROJECT
GOOGLE_CLOUD_LOCATION=global
VERTEX_API_KEY=YOUR_VERTEX_API_KEY

TEXT_PROCESSING_PROVIDER=langchain
GEMINI_LIVE_TEMPERATURE=0.4
GEMINI_LIVE_MAX_TOKENS=2048
GEMINI_LIVE_TOOLS=google_search
GEMINI_PRIMARY_MODEL=gemini-2.5-flash-lite
TEXT_PROCESSING_TEMPERATURE=0.4
FORWARD_ASSISTANT_ACTIONS=true
WEB_SEARCH_ENABLED=true

# =====================================================
# AZURE SPEECH TTS
# =====================================================
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY
AZURE_SPEECH_REGION=YOUR_AZURE_SPEECH_REGION
AZURE_VOICE_NAME=en-US-AriaNeural
AZURE_VOICE_STYLE=friendly
AZURE_SPEECH_RATE=1.0
AZURE_SPEECH_PITCH=1.0
AZURE_SPEECH_VOLUME=1.0
AZURE_AUDIO_FORMAT=riff-48khz-16bit-mono-pcm

# =====================================================
# gRPC / HTTP
# =====================================================
GRPC_HOST=auto
GRPC_PORT=50051
MAX_WORKERS=100
USE_TLS=false

HTTP_HOST=auto
HTTP_PORT=8080

# =====================================================
# VERSION / UPDATE
# =====================================================
SERVER_CHANNEL=dev
UPDATE_PORT=8081
UPDATE_HOST=auto
UPDATE_ENABLED=true
UPDATE_CORS=true
UPDATE_REQUIRE_HTTPS=false
UPDATE_VERIFY_SIGNATURES=true
UPDATE_LOG_REQUESTS=true
UPDATE_LOG_DOWNLOADS=true

# =====================================================
# DATABASE
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voice_assistant_db
DB_USER=nexy_user
DB_PASSWORD=YOUR_DB_PASSWORD

# =====================================================
# AUDIO
# =====================================================
SAMPLE_RATE=48000
CHUNK_SIZE=1024
AUDIO_FORMAT=int16
AUDIO_CODEC=pcm
AUDIO_CHANNELS=1
AUDIO_BITS_PER_SAMPLE=16
STREAMING_CHUNK_SIZE=4096
STREAMING_ENABLED=true

# =====================================================
# IMAGE
# =====================================================
IMAGE_FORMAT=webp
IMAGE_MIME_TYPE=image/webp
IMAGE_MAX_SIZE=10485760

# =====================================================
# SESSION / INTERRUPT
# =====================================================
MAX_SESSIONS=200
SESSION_TIMEOUT=3600
HARDWARE_ID_LENGTH=32

GLOBAL_INTERRUPT_ENABLED=true
INTERRUPT_CHECK_INTERVAL=0.1
INTERRUPT_TIMEOUT=5.0
GLOBAL_INTERRUPT_TIMEOUT=300
SESSION_INTERRUPT_TIMEOUT=60
MAX_ACTIVE_SESSIONS=100
SESSION_CLEANUP_DELAY=2.0

# =====================================================
# MEMORY
# =====================================================
MAX_SHORT_TERM_MEMORY_SIZE=51200
MAX_LONG_TERM_MEMORY_SIZE=102400
MEMORY_TIMEOUT=2.0
ANALYSIS_TIMEOUT=5.0
MEMORY_ANALYSIS_MODEL=gemini-2.5-flash-lite
MEMORY_ANALYSIS_TEMPERATURE=0.3

# =====================================================
# TEXT FILTERING
# =====================================================
FALLBACK_TIMEOUT=30
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=300
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=60
TEXT_CLEANING_ENABLED=true
CONTENT_FILTERING_ENABLED=true
MAX_TEXT_LENGTH=10000
MIN_TEXT_LENGTH=1

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO
LOG_REQUESTS=true
LOG_RESPONSES=false
LOG_FILE=server.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# =====================================================
# PERFORMANCE
# =====================================================
MAX_SENTENCE_LENGTH=200
MAX_REQUESTS_PER_MINUTE=1000
MAX_REQUESTS_PER_USER=10
MAX_MEMORY_USAGE=80

# =====================================================
# BROWSER / MESSAGES
# =====================================================
BROWSER_USE_ENABLED=true
BROWSER_USE_PRESET=ultra_fast
BROWSER_USE_KEEP_OPEN=true
BROWSER_USE_TIMEOUT=120
BROWSER_USE_MAX_STEPS=50
BROWSER_USE_MODEL=gemini-2.5-flash

MESSAGES_ENABLED=true

# =====================================================
# SUBSCRIPTION / STRIPE
# =====================================================
SUBSCRIPTION_ENABLED=true
SUBSCRIPTION_KILL_SWITCH=false
WHATSAPP_ENABLED=false
PAYMENT_USE_ENABLED=true
SUBSCRIPTION_TRIAL_DAYS=0
SUBSCRIPTION_PENDING_TTL=30
SUBSCRIPTION_GRANDFATHERED_ENABLED=true
SUBSCRIPTION_GRANDFATHER_AUTO_ASSIGN_EXISTING=true
SUBSCRIPTION_GRANDFATHER_CUTOFF_DATE=2026-02-23
SUBSCRIPTION_QUOTA_DAILY=25
SUBSCRIPTION_QUOTA_WEEKLY=125
SUBSCRIPTION_QUOTA_MONTHLY=500
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_TEST_PUBLISHABLE_KEY=YOUR_STRIPE_TEST_PUBLISHABLE_KEY
STRIPE_TEST_WEBHOOK_SECRET=YOUR_STRIPE_TEST_WEBHOOK_SECRET
STRIPE_TEST_PRICE_ID=YOUR_STRIPE_TEST_PRICE_ID
STRIPE_LIVE_SECRET_KEY=YOUR_STRIPE_LIVE_SECRET_KEY
STRIPE_LIVE_PUBLISHABLE_KEY=YOUR_STRIPE_LIVE_PUBLISHABLE_KEY
STRIPE_LIVE_WEBHOOK_SECRET=YOUR_STRIPE_LIVE_WEBHOOK_SECRET
STRIPE_LIVE_PRICE_ID=YOUR_STRIPE_LIVE_PRICE_ID
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID=YOUR_STRIPE_PRICE_ID
